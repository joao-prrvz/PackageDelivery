/** @var Employee[] $employees */ 
/** @var Package[] $packages */ 
/** @var HomeSearch $search */ 

/**
 * @param PackageStatus $status
 */
function getStatusBadgeColor(PackageStatus $status) {
    switch($status) {
        case PackageStatus::DELIVERED:
            return "success";
        case PackageStatus::DELIVERING:
            return "warning";
        case PackageStatus::NOT_DELIVERED:
            return "error";
    }
    return "primary";
}

?>
<main class="flex-1 flex overflow-hidden">
<div class="w-full h-full flex justify-evenly items-center p-4">
    <div class="flex items-end h-full w-150 ">
        <form class="h-full bg-base-200 rounded w-full p-4 flex flex-col">
            <h1 class="text-2xl font-bold text-center mb-4">Packages</h1>
            <div class="join w-full">
                <label class="join-item input flex-1">
                    <i class="bi bi-search"></i>
                    <input type="search" class="grow" placeholder="Search" name="pkgQuery" value="<?= $search->pkgQuery?>" />
                    <input class="hidden" type="search"name="emplQuery" value="<?= $search->emplQuery?>" />
                </label>
                <button class="btn btn-primary join-item">Search</button>
            </div>
            <ul class="menu bg-base-100 rounded-box shadow-md my-4 flex-1 overflow-y-auto w-full overflow-x-hidden flex-col flex-nowrap">
                <? foreach($packages as $pkg): ?>
                <li>
                    <a class="p-4" onclick="packageOnClick(event)" data-id="<?= $pkg->id ?>" >
